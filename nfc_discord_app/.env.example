# Discord webhook URL (required)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Cooldown in seconds to prevent duplicate sends for the same tag
COOLDOWN_SECONDS=5

# State reset hours (time after which a user is automatically marked as OUT)
STATE_RESET_HOURS=12

# Discord OAuth2 Settings
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
FLASK_SECRET_KEY=somesecretkey

# NFC reader USB path (カンマ区切りで複数指定可。先頭から順に接続を試みる)
# RC-S380: usb:054c:06c1
# RC-S956: usb:054c:0dc8  ※デバイスマネージャー > プロパティ > ハードウェアIDで要確認
# どちらか一方だけ使う場合はそのパスのみ記載
# 接続する機器を自動検出する場合は "usb" のみ指定
NFC_READER_PATH=usb:054c:06c1,usb:054c:0dc8

# HTTP timeout for webhook requests in seconds
WEBHOOK_TIMEOUT_SECONDS=10

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
